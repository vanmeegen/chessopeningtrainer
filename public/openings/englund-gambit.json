                    "children": [],
                    "isMainLine": false,
                    "annotation": {
                      "moveRationale": "White declines the gambit by supporting the pawn. This position looks similar to the French defense, as the name suggests.",
                      "strategicTheme": "Gambit play",
                      "source": "wikibooks"
                    }
                  }
